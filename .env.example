# Required: OpenWeatherMap One Call API 3.0
# Sign up at https://openweathermap.org/api — subscribe to One Call 3.0 (free for 1000 calls/day)
OPENWEATHERMAP_API_KEY=your_key_here

# Optional: Google Calendar (for calendar events)
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Optional: Google Pollen API
# Enable at https://console.cloud.google.com/apis/library/pollen.googleapis.com
GOOGLE_POLLEN=your_key_here
